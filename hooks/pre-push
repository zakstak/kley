#!/usr/bin/env bash

set -euo pipefail

run_check() {
  local label="$1"
  shift

  printf '\n==> %s\n' "$label"
  "$@"
}

if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
  printf 'ERROR: pre-push hook must run inside a git repository.\n' >&2
  exit 1
fi

cd "$repo_root"

if command -v gitleaks >/dev/null 2>&1; then
  run_check "Scanning repository for secrets" gitleaks detect --source . --verbose
else
  printf 'WARNING: gitleaks not found - skipping secret scan\n' >&2
fi

if ! command -v cargo >/dev/null 2>&1; then
  printf 'ERROR: cargo not found - cannot verify fmt/clippy/test/build checks before push.\n' >&2
  exit 1
fi

run_check "Running cargo fmt --check" cargo fmt --check
run_check "Running cargo clippy -- -D warnings" cargo clippy -- -D warnings
run_check "Running cargo test" cargo test
run_check "Running cargo build --release" cargo build --release
